PORT=5000
MONGO_URI=mongodb://localhost:27017/lms
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d
NODE_ENV=development

# Redis Configuration (for OCR job queue)
REDIS_URL=redis://127.0.0.1:6379

# ML Server Configuration
# OPTION 1: Single Worker (backward compatible)
# LOCAL: Use http://localhost:8000 (when running ML server locally)
# DEPLOYED: Use https://YOUR_USERNAME-SPACE_NAME.hf.space (your Hugging Face Space URL)
ML_SERVER_URL=http://localhost:8000

# OPTION 2: Multiple Workers (for load balancing and scalability)
# Comma-separated list of worker URLs
# Example: ML_WORKER_URLS=http://localhost:8001,http://localhost:8002,http://localhost:8003
# For production: ML_WORKER_URLS=https://worker1.domain.com,https://worker2.domain.com
# ML_WORKER_URLS=

# OCR Processing Concurrency
# How many jobs can be processed in parallel (default: 10)
# Increase for better throughput with multiple workers
# OCR_CONCURRENCY=10

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=noreply@lms.com
EMAIL_FROM_NAME=LMS System

# Client URL
CLIENT_URL=http://localhost:3000
